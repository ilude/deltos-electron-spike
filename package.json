{
	"name": "deltos-electron-spike",
	"version": "1.0.0",
	"description": "Deltos Electron spike project",
	"main": "dist/main.js",
	"scripts": {
		"build": "bun build src/main.ts src/preload.ts --outdir dist --target node --format cjs --external electron --external node-pty && bun build src/renderer.ts --outdir dist --target browser && cp node_modules/@xterm/xterm/css/xterm.css dist/xterm.css",
		"start": "bun run build && electron .",
		"dev": "bun run build && electron ."
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"electron": "^40.6.1",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.0",
		"@codemirror/commands": "^6.10.2",
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/lang-javascript": "^6.2.4",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language": "^6.12.2",
		"@codemirror/lint": "^6.9.4",
		"@codemirror/search": "^6.6.0",
		"@codemirror/state": "^6.5.4",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.39.15",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"codemirror": "^6.0.2",
		"node-pty": "^1.1.0"
	}
}
